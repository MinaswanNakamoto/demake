\t@test -d $(OBJECT) |||| mkdir $(OBJECT)
else
\t@mkdir -p $(BINARY)
\t@mkdir -p $(OBJECT)
endif
\t$(CC) $(LIBS) $(DEBUG_FLAGS) -c $< -o $@
END_OF_STRING
if(@emojis == false)
  strip_emojis!(dependency_targets)
end
