\t@test -d $(BINARY) |||| mkdir $(BINARY)
else
\t@mkdir -p $(BINARY)
endif
\t$(CC) $(LIBS) $(CFLAGS) -o $(BINARY)/#{app[0]} $(OL#{counter})#{@raw_binary_files}
END_OF_STRING
  @output << "\n"
