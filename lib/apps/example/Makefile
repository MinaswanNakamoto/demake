# Dependencies
$(OBJECT)/string/string.o : $(SOURCE)/string/string.c   \
        $(SOURCE)/string/string.h
        @echo "║ 🛠  Compiling... $(OBJECT)/string/string.o"
ifeq '$(OS)' 'Windows_NT'
        @test -d $(OBJECT)/string/ || mkdir $(OBJECT)/string/
else
        @mkdir -p $(OBJECT)/string/
endif
        $(CC) $(BUILD_FLAGS) $(LIBS) -c $(SOURCE)/string/string.c -o $(OBJECT)/string/string.o
