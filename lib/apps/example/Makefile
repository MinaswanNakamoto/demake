.PHONY : build
build : LICENSE
        @echo "╔═════════════════════════════════════════════════════════════════════════╗"
        @echo "║ 🚧  Building executable: bin/hello                                      ║"
        @echo "╚═════════════════════════════════════════════════════════════════════════╝"
        @$(MAKE) $(BINARY)/hello
        @if command -v $(STRIP) >/dev/null 2>&1 ; then    echo "Stripping $(BINARY)/hello";       $(STRIP) $(STRIP_ARGS) $(BINARY)/hello || echo "Warning: strip failed for $(BINARY)/hello";  else      echo "strip not found; skipping strip step";  fi
        @echo "╔═════════════════════════════════════════════════════════════════════════╗"
        @echo "║ 🚧  Building executable: bin/goodbye                                    ║"
        @echo "╚═════════════════════════════════════════════════════════════════════════╝"
        @$(MAKE) $(BINARY)/goodbye
        @if command -v $(STRIP) >/dev/null 2>&1 ; then    echo "Stripping $(BINARY)/goodbye";     $(STRIP) $(STRIP_ARGS) $(BINARY)/goodbye || echo "Warning: strip failed for $(BINARY)/goodbye";      else      echo "strip not found; skipping strip step";  fi

