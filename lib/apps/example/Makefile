# General Auto-Dependencies
$(OBJECT)/%.o : $(SOURCE)/%.c
        @echo "║ 🛠  Compiling... $(@)"
ifeq '$(OS)' 'Windows_NT'
        @test -d $(BINARY) || mkdir $(BINARY)
        @test -d $(OBJECT) || mkdir $(OBJECT)
else
        @mkdir -p $(BINARY)
        @mkdir -p $(OBJECT)
endif
        $(CC) $(BUILD_FLAGS) $(LIBS) -c $< -o $@
# General Auto-Dependencies for debug
# $(OBJECT)/%_debug.o : BUILD_FLAGS := $(DEBUG_FLAGS) $(CFLAGS)
#
$(OBJECT)/%_debug.o : $(SOURCE)/%.c
        @echo "║ 🐛  🛠  Compiling... $(@)"
ifeq '$(OS)' 'Windows_NT'
        @test -d $(BINARY) || mkdir $(BINARY)
        @test -d $(OBJECT) || mkdir $(OBJECT)
else
        @mkdir -p $(BINARY)
        @mkdir -p $(OBJECT)
endif
        $(CC) $(BUILD_FLAGS) $(LIBS) -c $< -o $@

.PHONY : clean
clean :
        @echo "🔥  Removed everything from $(OBJECT), $(BINARY), and $(LIBRARY) directories"
        @rm -rf $(OBJECT) $(BINARY) $(LIBRARY)

.PHONY : debug
debug : LICENSE
        @echo "╔═════════════════════════════════════════════════════════════════════════╗"
        @echo "║ 🐛  🚧  Building executable: bin/hello_debug                            ║"
        @echo "╚═════════════════════════════════════════════════════════════════════════╝"
        @$(MAKE) $(BINARY)/hello_debug
        @echo "╔═════════════════════════════════════════════════════════════════════════╗"
        @echo "║ 🐛  🚧  Building executable: bin/goodbye_debug                          ║"
        @echo "╚═════════════════════════════════════════════════════════════════════════╝"
        @$(MAKE) $(BINARY)/goodbye_debug

test : LICENSE build
        @echo -n "❓ Running tests:"
        @echo
        @echo "Testing command hello:"
        bin/hello
        @echo "Testing command goodbye:"
        bin/goodbye

.PHONY : install
install : LICENSE
        @echo "🔩  Starting install..."
        @test -d $(PREFIX) | install -d $(PREFIX)
        @test -f bin/hello && install -v -m 755 bin/hello $(PREFIX) || \
                (echo "Executable file bin/hello not found."; \
                echo "Please type 'make build' first, if you wish to install.")
        @test -f bin/goodbye && install -v -m 755 bin/goodbye $(PREFIX) || \
                (echo "Executable file bin/goodbye not found."; \
                echo "Please type 'make build' first, if you wish to install.")
        @echo "🔩  ✔  Installation Finished"

.PHONY : uninstall
uninstall :
        @echo "🔧  Starting uninstall..."
        rm -f $(PREFIX)hello
        rm -f $(PREFIX)goodbye
ifneq '$(OS)' 'FreeBSD'
        rmdir --ignore-fail-on-non-empty $(PREFIX)
endif
        @echo "🔧  ✔  Uninstall Finished"
